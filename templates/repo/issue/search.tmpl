<form class="list-header-search ui form ignore-dirty issue-list-search">
	<div class="ui search fluid action input">
		<input type="hidden" name="state" value="{{$.State}}">
		{{if not .PageIsMilestones}}
			<input type="hidden" name="type" value="{{$.ViewType}}">
			<input type="hidden" name="labels" value="{{.SelectLabels}}">
			<input type="hidden" name="milestone" value="{{$.MilestoneID}}">
			<input type="hidden" name="project" value="{{$.ProjectID}}">
			<input type="hidden" name="assignee" value="{{$.AssigneeID}}">
			<input type="hidden" name="poster" value="{{$.PosterID}}">
			<input type="hidden" name="sort" value="{{$.SortType}}">
		{{end}}
		<span class="datahub-search-filter-prefix">Filters</span>
		{{if .PageIsPullList}}
			{{template "shared/search/input" dict "Value" .Keyword "Placeholder" (ctx.Locale.Tr "search.pull_kind")}}
		{{else if .PageIsMilestones}}
			{{template "shared/search/input" dict "Value" .Keyword "Placeholder" (ctx.Locale.Tr "search.milestone_kind")}}
		{{else}}
			{{template "shared/search/input" dict "Value" .Keyword "Placeholder" (ctx.Locale.Tr "search.issue_kind")}}
		{{end}}
		{{template "shared/search/button" dict "Tooltip" (ctx.Locale.Tr "explore.go_to")}}
	</div>
	{{if not .PageIsMilestones}}
		{{template "shared/search/issue/syntax"}}
	{{end}}
</form>
