# Deprecated: use ./Dockerfile for datahub-gateway deployments.
#
# The root Forgejo Dockerfile preserves the official entrypoint, bindata build,
# SQLite tags, and FORGEJO__section__KEY environment-to-app.ini wiring. This
# legacy file intentionally fails fast so a production build cannot silently
# produce an incomplete gateway image.
FROM alpine:3.20
RUN echo "Dockerfile.datahub is deprecated; build with -f Dockerfile instead." >&2 && exit 1
